# Frontend Proxy Server Configuration

# Backend API URL (hidden from clients)
VITE_API_BASE_URL=http://localhost:8000

# Proxy server port
PROXY_PORT=3001

# Allowed origins (frontend URLs that can request documents)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Production example:
# VITE_API_BASE_URL=https://api.claimchase.com
# PROXY_PORT=3001
# ALLOWED_ORIGINS=https://claimchase.com,https://www.claimchase.com
